@page "/consignees"
@using MessagebirdTools.WebApp.Components.Dialogs
@using MessagebirdTools.WebApp.Models
@using MessagebirdTools.WebApp.Services
@inject IScheduleDataService DataService
@inject ISettingsService SettingsService
@inject IExcelImportExportService ExcelService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime

<PageTitle>Consignees Management</PageTitle>

<MudText Typo="Typo.h3" GutterBottom="true">Consignees Management</MudText>

@if (!isInitialized)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
    <MudText>Initializing...</MudText>
}
else
{
    <MudPaper Class="pa-4 mb-4">
        <MudStack Row="true" Spacing="2">
            <MudButton Variant="MudBlazor.Variant.Filled" Color="Color.Primary" OnClick="OpenAddDialog" StartIcon="@Icons.Material.Filled.PersonAdd">Add New Personnel</MudButton>
            <MudSpacer />
            <MudMenu Label="Excel" StartIcon="@Icons.Material.Filled.TableChart" Variant="MudBlazor.Variant.Outlined" Color="Color.Default">
                <MudMenuItem OnClick="ImportFromExcel" Icon="@Icons.Material.Filled.Upload">Import from Excel</MudMenuItem>
                <MudMenuItem OnClick="ExportToExcel" Icon="@Icons.Material.Filled.Download">Export to Excel</MudMenuItem>
            </MudMenu>
        </MudStack>
    </MudPaper>

    @if (consigneesList.Count == 0)
    {
        <MudAlert Severity="Severity.Info">No personnel records found. Add a new personnel record to get started.</MudAlert>
    }
    else
    {
        <MudTable Items="@consigneesList" Hover="true" Filter="new Func<Consignee, bool>(FilterFunc)">
            <ToolBarContent>
                <MudTextField @bind-Value="searchString" Placeholder="Search" Adornment="Adornment.Start" 
                              AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
            </ToolBarContent>
            <HeaderContent>
                <MudTh>#</MudTh>
                <MudTh>Name</MudTh>
                <MudTh>Email</MudTh>
                <MudTh>Phone</MudTh>
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Key">@context.Key</MudTd>
                <MudTd DataLabel="Name">@context.Name</MudTd>
                <MudTd DataLabel="Email">@context.Email</MudTd>
                <MudTd DataLabel="Phone">@context.Phone</MudTd>
                <MudTd>
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="@(() => OpenEditDialog(context))" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" OnClick="@(() => OpenDeleteDialog(context))" />
                </MudTd>
            </RowTemplate>
        </MudTable>
    }
}

<InputFile id="excelFileInputConsignees" OnChange="OnExcelFileSelected" style="display: none;" accept=".xlsx,.xls" />

@code {
    private bool isInitialized = false;
    private List<Consignee> consigneesList = new();
    private List<Schedule> scheduleList = new();
    private string searchString = "";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await SettingsService.InitializeAsync();
            await DataService.InitializeAsync();
            RefreshData();
            isInitialized = true;
            StateHasChanged();
        }
    }

    private void RefreshData()
    {
        consigneesList = DataService.GetAllConsignees();
        scheduleList = DataService.GetAllSchedules();
    }

    private bool FilterFunc(Consignee consignee)
    {
        if (string.IsNullOrWhiteSpace(searchString))
            return true;
            
        return (consignee.Name?.Contains(searchString, StringComparison.OrdinalIgnoreCase) ?? false) ||
               (consignee.Email?.Contains(searchString, StringComparison.OrdinalIgnoreCase) ?? false) ||
               (consignee.Phone?.Contains(searchString, StringComparison.OrdinalIgnoreCase) ?? false);
    }

    private async Task OpenAddDialog()
    {
        var dialog = DialogService.Show<ConsigneeDialog>("Add Personnel");
        var result = await dialog.Result;
        
        if (!result.Canceled)
        {
            var newConsignee = (Consignee)result.Data;
            DataService.AddConsignee(newConsignee);
            RefreshData();
            Snackbar.Add("Personnel added. Click Publish to sync with Messagebird.", Severity.Success);
        }
    }

    private async Task OpenEditDialog(Consignee consignee)
    {
        var parameters = new DialogParameters
        {
            ["Consignee"] = consignee
        };
        
        var dialog = DialogService.Show<ConsigneeDialog>("Edit Consignee", parameters);
        var result = await dialog.Result;
        
        if (!result.Canceled)
        {
            var updatedConsignee = (Consignee)result.Data;
            DataService.UpdateConsignee(updatedConsignee);
            RefreshData();
            Snackbar.Add("Personnel updated. Click Publish to sync with Messagebird.", Severity.Success);
        }
    }

    private async Task OpenDeleteDialog(Consignee consignee)
    {
        var result = await ConfirmDialog.Show(
            DialogService, 
            title: "Confirm Delete", 
            contentText: $"Are you sure you want to delete {consignee.Name}? This action cannot be undone.", 
            submitButtonText: "Delete");
        
        if (!result.Canceled)
        {
            DataService.DeleteConsignee(consignee.Key);
            RefreshData();
            Snackbar.Add("Consignee deleted. Click Publish to sync with Messagebird.", Severity.Success);
        }
    }

    private async Task ImportFromExcel()
    {
        // Trigger the hidden file input
        await JSRuntime.InvokeVoidAsync("document.getElementById('excelFileInputConsignees').click");
    }

    private async Task OnExcelFileSelected(InputFileChangeEventArgs e)
    {
        try
        {
            var file = e.File;
            if (file == null)
                return;

            using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024); // 10MB max
            using var memoryStream = new MemoryStream();
            await stream.CopyToAsync(memoryStream);
            memoryStream.Position = 0;

            var (importedConsignees, importedSchedules) = await ExcelService.ImportFromExcelAsync(memoryStream);

            // Import with merge (not replace)
            if (importedConsignees.Count > 0)
            {
                DataService.ImportConsignees(importedConsignees, replace: false);
            }
            
            if (importedSchedules.Count > 0)
            {
                DataService.ImportSchedules(importedSchedules, replace: false);
            }

            RefreshData();
            Snackbar.Add($"Imported {importedConsignees.Count} consignees and {importedSchedules.Count} schedules. Click Publish to sync with Messagebird.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error importing Excel file: {ex.Message}", Severity.Error);
        }
    }

    private async Task ExportToExcel()
    {
        try
        {
            var stream = await ExcelService.ExportToExcelStreamAsync(consigneesList, scheduleList);
            var fileName = $"consignees-export-{DateTime.Now:yyyy-MM-dd-HHmmss}.xlsx";
            
            // Convert to base64 and trigger download
            var bytes = stream.ToArray();
            var base64 = Convert.ToBase64String(bytes);
            await JSRuntime.InvokeVoidAsync("eval", $"(function(){{var a=document.createElement('a');a.href='data:application/vnd.openxmlformats-officedocument.spreadsheetml.sheet;base64,{base64}';a.download='{fileName}';document.body.appendChild(a);a.click();document.body.removeChild(a);}})()");
            
            Snackbar.Add($"Exported to {fileName}", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error exporting to Excel: {ex.Message}", Severity.Error);
        }
    }
}