@page "/"
@using MudBlazor

<PageTitle>Home - MessagebirdTools</PageTitle>

<MudText Typo="Typo.h3" GutterBottom="true">
    <MudIcon Icon="@Icons.Material.Filled.Home" Class="mr-2" />
    Welkom bij MessagebirdTools
</MudText>
<MudText Class="mb-4">Een applicatie voor het beheren van consignees en schedules, met synchronisatie naar Messagebird.</MudText>

<MudDivider Class="mb-6" />

<MudGrid>
    <MudItem xs="12" md="6">
        <MudPaper Class="pa-4 mb-4" Elevation="2">
            <MudText Typo="Typo.h5" GutterBottom="true">
                <MudIcon Icon="@Icons.Material.Filled.MenuBook" Class="mr-2" Color="Color.Primary" />
                Snelstart Gids
            </MudText>
            
            <MudTimeline TimelinePosition="TimelinePosition.Start" TimelineAlign="TimelineAlign.Start">
                <MudTimelineItem Color="Color.Primary" Size="Size.Small">
                    <MudText Typo="Typo.h6">1. Configureer API Instellingen</MudText>
                    <MudText Typo="Typo.body2">
                        Ga naar <MudLink Href="/settings">Settings</MudLink> en configureer uw Messagebird API credentials:
                        API Key, Database Key en Database Record Key.
                    </MudText>
                </MudTimelineItem>
                
                <MudTimelineItem Color="Color.Info" Size="Size.Small">
                    <MudText Typo="Typo.h6">2. Haal Data Op</MudText>
                    <MudText Typo="Typo.body2">
                        Klik op de <strong>Fetch</strong> knop in de werkbalk om bestaande data van Messagebird op te halen,
                        of begin met lege data als dit uw eerste keer is.
                    </MudText>
                </MudTimelineItem>
                
                <MudTimelineItem Color="Color.Primary" Size="Size.Small">
                    <MudText Typo="Typo.h6">3. Beheer Consignees</MudText>
                    <MudText Typo="Typo.body2">
                        Voeg consignees toe via de <MudLink Href="/consignees">Consignees</MudLink> pagina.
                        Dit zijn de personen die aan schedules gekoppeld kunnen worden.
                    </MudText>
                </MudTimelineItem>
                
                <MudTimelineItem Color="Color.Success" Size="Size.Small">
                    <MudText Typo="Typo.h6">4. Plan Schedules</MudText>
                    <MudText Typo="Typo.body2">
                        Maak schedules aan op de <MudLink Href="/scheduling">Scheduling</MudLink> pagina.
                        Bekijk ze in tabel- of kalenderweergave.
                    </MudText>
                </MudTimelineItem>
            </MudTimeline>
        </MudPaper>
    </MudItem>
    
    <MudItem xs="12" md="6">
        <MudPaper Class="pa-4 mb-4" Elevation="2">
            <MudText Typo="Typo.h5" GutterBottom="true">
                <MudIcon Icon="@Icons.Material.Filled.CloudSync" Class="mr-2" Color="Color.Success" />
                Synchroniseren met Messagebird
            </MudText>
            <MudText Typo="Typo.body2" Class="mb-4">
                Messagebird is de centrale opslag voor al uw data. Gebruik de knoppen in de werkbalk om te synchroniseren:
            </MudText>
            
            <MudStack Spacing="3">
                <MudAlert Severity="Severity.Info" Variant="MudBlazor.Variant.Filled" Dense="true">
                    <MudStack Row="true" AlignItems="MudBlazor.AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Filled.CloudDownload" />
                        <div>
                            <MudText Typo="Typo.subtitle2"><strong>Fetch</strong></MudText>
                            <MudText Typo="Typo.body2">Haalt de meest recente data op van Messagebird</MudText>
                        </div>
                    </MudStack>
                </MudAlert>
                
                <MudAlert Severity="Severity.Success" Variant="MudBlazor.Variant.Filled" Dense="true">
                    <MudStack Row="true" AlignItems="MudBlazor.AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Filled.Publish" />
                        <div>
                            <MudText Typo="Typo.subtitle2"><strong>Publish</strong></MudText>
                            <MudText Typo="Typo.body2">Publiceert uw wijzigingen naar Messagebird</MudText>
                        </div>
                    </MudStack>
                </MudAlert>
            </MudStack>
            
            <MudDivider Class="my-4" />
            
            <MudAlert Severity="Severity.Warning" Dense="true">
                <MudText Typo="Typo.body2">
                    <MudIcon Icon="@Icons.Material.Filled.Warning" Size="Size.Small" Class="mr-1" />
                    Wanneer u niet-gepubliceerde wijzigingen heeft, verschijnt er een indicator in de werkbalk.
                    Klik op <strong>Publish</strong> om uw wijzigingen op te slaan.
                </MudText>
            </MudAlert>
        </MudPaper>
    </MudItem>
</MudGrid>

<MudGrid Class="mt-4">
    <MudItem xs="12" md="4">
        <MudPaper Class="pa-4" Elevation="2" Style="height: 100%;">
            <MudStack Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.People" Color="Color.Primary" Size="Size.Large" />
                <MudText Typo="Typo.h6">Consignees Beheer</MudText>
                <MudText Typo="Typo.body2">
                    Voeg consignees toe, bewerk of verwijder ze. Elk consignee heeft een unieke ID, naam, email en telefoonnummer.
                </MudText>
                <MudButton Variant="MudBlazor.Variant.Outlined" Color="Color.Primary" Href="/consignees" StartIcon="@Icons.Material.Filled.ArrowForward">
                    Ga naar Consignees
                </MudButton>
            </MudStack>
        </MudPaper>
    </MudItem>
    
    <MudItem xs="12" md="4">
        <MudPaper Class="pa-4" Elevation="2" Style="height: 100%;">
            <MudStack Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.CalendarMonth" Color="Color.Secondary" Size="Size.Large" />
                <MudText Typo="Typo.h6">Planning Beheer</MudText>
                <MudText Typo="Typo.body2">
                    Plan schedules met start- en eindtijd. Bekijk ze in een overzichtelijke tabel of kalender weergave.
                </MudText>
                <MudButton Variant="MudBlazor.Variant.Outlined" Color="Color.Secondary" Href="/scheduling" StartIcon="@Icons.Material.Filled.ArrowForward">
                    Ga naar Scheduling
                </MudButton>
            </MudStack>
        </MudPaper>
    </MudItem>
    
    <MudItem xs="12" md="4">
        <MudPaper Class="pa-4" Elevation="2" Style="height: 100%;">
            <MudStack Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.Settings" Color="Color.Tertiary" Size="Size.Large" />
                <MudText Typo="Typo.h6">Instellingen</MudText>
                <MudText Typo="Typo.body2">
                    Configureer uw Messagebird API credentials voor toegang tot de database.
                </MudText>
                <MudButton Variant="MudBlazor.Variant.Outlined" Color="Color.Tertiary" Href="/settings" StartIcon="@Icons.Material.Filled.ArrowForward">
                    Ga naar Settings
                </MudButton>
            </MudStack>
        </MudPaper>
    </MudItem>
</MudGrid>

<MudPaper Class="pa-4 mt-6" Elevation="2">
    <MudText Typo="Typo.h5" GutterBottom="true">
        <MudIcon Icon="@Icons.Material.Filled.Help" Class="mr-2" Color="Color.Info" />
        Veelgestelde Vragen
    </MudText>
    
    <MudExpansionPanels MultiExpansion="true" Class="mt-4">
        <MudExpansionPanel>
            <TitleContent>
                <MudText Typo="Typo.h6">Wat gebeurt er als ik wijzigingen maak maar niet publiceer?</MudText>
            </TitleContent>
            <ChildContent>
                <MudText Typo="Typo.body2">
                    Alle wijzigingen worden tijdelijk in het geheugen bewaard. Als u de applicatie sluit zonder te publiceren,
                    gaan deze wijzigingen verloren. De werkbalk toont een waarschuwing wanneer u niet-gepubliceerde wijzigingen heeft.
                    Klik op <strong>Publish</strong> om uw wijzigingen permanent op te slaan in Messagebird.
                </MudText>
            </ChildContent>
        </MudExpansionPanel>
        
        <MudExpansionPanel>
            <TitleContent>
                <MudText Typo="Typo.h6">Wat is het verschil tussen Fetch en Publish?</MudText>
            </TitleContent>
            <ChildContent>
                <MudText Typo="Typo.body2">
                    <strong>Fetch</strong> haalt de meest recente data op van de Messagebird database. 
                    Dit overschrijft uw lokale wijzigingen.<br />
                    <strong>Publish</strong> stuurt uw huidige wijzigingen naar de Messagebird database,
                    waardoor ze permanent worden opgeslagen.
                </MudText>
            </ChildContent>
        </MudExpansionPanel>
        
        <MudExpansionPanel>
            <TitleContent>
                <MudText Typo="Typo.h6">Kan ik data importeren of exporteren naar Excel?</MudText>
            </TitleContent>
            <ChildContent>
                <MudText Typo="Typo.body2">
                    Ja! Op de Scheduling en Consignees pagina's vindt u een <strong>Excel</strong> menu 
                    waarmee u data kunt importeren vanuit een Excel bestand of exporteren naar Excel.
                    Dit is handig voor bulk wijzigingen of om een backup te maken van uw data.
                    Na het importeren moet u nog steeds op <strong>Publish</strong> klikken om de wijzigingen 
                    naar Messagebird te versturen.
                </MudText>
            </ChildContent>
        </MudExpansionPanel>
        
        <MudExpansionPanel>
            <TitleContent>
                <MudText Typo="Typo.h6">Waar worden mijn API credentials opgeslagen?</MudText>
            </TitleContent>
            <ChildContent>
                <MudText Typo="Typo.body2">
                    Uw API credentials worden veilig opgeslagen in de lokale opslag van uw browser.
                    Ze worden niet gedeeld met andere browsers of apparaten. U kunt ze bekijken 
                    en wijzigen op de Settings pagina.
                </MudText>
            </ChildContent>
        </MudExpansionPanel>
    </MudExpansionPanels>
</MudPaper>

<MudPaper Class="pa-4 mt-4 mb-4" Elevation="2">
    <MudStack Row="true" Justify="MudBlazor.Justify.SpaceBetween" AlignItems="MudBlazor.AlignItems.Center">
        <div>
            <MudText Typo="Typo.h6">Klaar om te beginnen?</MudText>
            <MudText Typo="Typo.body2">Start met het configureren van uw API instellingen.</MudText>
        </div>
        <MudButton Variant="MudBlazor.Variant.Filled" Color="Color.Primary" Size="Size.Large" Href="/settings" EndIcon="@Icons.Material.Filled.ArrowForward">
            Naar Instellingen
        </MudButton>
    </MudStack>
</MudPaper>